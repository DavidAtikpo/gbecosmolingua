				{
					"color": "#f7f1df",
					"name": "Parchemin",
					"slug": "gbe-sand"
				},
				{
					"color": "#8a4a12",
					"name": "Cuivre",
					"slug": "gbe-copper"
				},
				{
					"color": "#23150c",
					"name": "Encre brune",
					"slug": "gbe-ink"
